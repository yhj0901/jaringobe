# ================= 자린고비 환경변수 템플릿 =================
# 실제 .env 는 커밋 금지 (.gitignore 처리). 이 파일만 커밋.

# --- PostgreSQL ---
POSTGRES_USER=jaringobe
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=jaringobe

# --- 백엔드 DB 연결 (docker-compose 내부 네트워크: host=db) ---
DATABASE_URL=postgresql+asyncpg://jaringobe:change-me-in-prod@db:5432/jaringobe

# --- 인증 (JWT + 소셜 로그인) ---
# JWT_SECRET: 64자 이상 랜덤 문자열 권장 (예: openssl rand -hex 32)
JWT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 애플 로그인(P1) 도입 시 추가: APPLE_CLIENT_ID / APPLE_TEAM_ID / APPLE_KEY_ID / APPLE_PRIVATE_KEY_PATH

# --- 프론트엔드 오리진 (Origin 검증·OAuth 복귀 리다이렉트 베이스) ---
FRONTEND_ORIGIN=http://localhost:3000

# --- 쿠키 보안 (배포 https 환경에서는 반드시 true) ---
COOKIE_SECURE=false

# --- 프론트엔드 rewrites 대상 백엔드 주소 (Next.js) ---
BACKEND_URL=http://localhost:8000

# --- LLM (Claude API) ---
# 비어 있으면 백엔드가 mock 모드로 표시됨. 실제 키는 여기에만 입력.
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-5

# --- 마트 연동 (네이버 쇼핑 검색 API) ---
# developers.naver.com 에서 발급. 비어 있으면 store 검색 결과 없음.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# --- 푸시 알림 (Expo Push Service) ---
# expo.dev 계정의 Access Token. 비어 있으면 무인증 발송 시도 (개발용).
EXPO_ACCESS_TOKEN=

# --- 앱 딥링크 (모바일 웹뷰 앱 로그인 복귀 스킴) ---
APP_SCHEME=jaringobe

# --- 식단 생성/리마인더 운영 파라미터 (기본값 있음 — 필요 시만 변경) ---
# MEALPLAN_GENERATION_TIMEOUT_MINUTES=10   # processing 좀비 수렴 시간
# REMINDER_SCHEDULER_ENABLED=true
# REMINDER_SCHEDULER_INTERVAL_SECONDS=30
